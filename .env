# ===========================================================
# .env
# -----------------------------------------------------------
# Local environment variables for SBT (BusTrack)
# Ignored by Git for security and cleanliness
# ===========================================================

# --- Database configuration ---
DATABASE_URL=sqlite:///sbt.db       # SQLite database file for local development
# For production (PostgreSQL), replace with:
# DATABASE_URL=postgresql://user:password@localhost:5432/sbt

# --- Security key ---
SECRET_KEY=change_this_key          # Used later for JWT authentication and encryption

# --- App environment ---
APP_NAME=SBT                        # Application name
APP_ENV=development                 # Set to "production" when deploying
APP_VERSION=1.0

# --- Optional integrations (future use) ---
# MAIL_USERNAME=
# MAIL_PASSWORD=
# GPS_API_KEY=
